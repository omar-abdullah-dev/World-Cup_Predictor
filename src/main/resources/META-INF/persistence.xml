<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="WorldCupPU" transaction-type="JTA">
        <description>World Cup Predictor JPA persistence unit (PostgreSQL)</description>

        <jta-data-source>java:jboss/datasources/WorldCupDS</jta-data-source>

        <class>com.worldcup.model.User</class>
        <class>com.worldcup.model.Match</class>
        <class>com.worldcup.model.Prediction</class>
        <class>com.worldcup.model.Team</class>
        <class>com.worldcup.model.Group</class>
        <class>com.worldcup.model.TournamentRound</class>
        <class>com.worldcup.model.WhitelistEntry</class>
        <class>com.worldcup.model.SystemActivityLog</class>
        <class>com.worldcup.model.UserSession</class>

        <properties>
            <!-- Hibernate dialect for PostgreSQL -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <!-- Auto-create/update schema on deploy (use validate in production) -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
